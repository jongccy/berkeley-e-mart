NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required in production for the hourly sold-listing expiry cron (Vercel → Settings → Environment Variables)
CRON_SECRET=generate-a-long-random-string

# Required for the sold-listing expiry cron and `npm run seed:demo` (Supabase → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: transactional email when someone receives a new inbox message (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Calket <notifications@your-verified-domain.com>
